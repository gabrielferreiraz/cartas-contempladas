# Copie cada bloco para o .env do subdiretório correspondente.
# Este arquivo é apenas referência — não é lido por nenhum serviço.

# === packages/worker/.env ===
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<sua-service-role-key>
SHEETS_IMOVEIS_CSV_URL=https://docs.google.com/spreadsheets/d/<id>/export?format=csv&gid=<gid>
SHEETS_AUTOMOVEIS_CSV_URL=https://docs.google.com/spreadsheets/d/<id>/export?format=csv&gid=<gid>
SYNC_INTERVAL_MINUTES=5
SOLD_THRESHOLD=2
NODE_ENV=production

# === packages/web/.env ===
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<sua-anon-key>
